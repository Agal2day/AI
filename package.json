{
  "name": "code-learning-assistant",
  "description": "A code learning assistant with AI analysis",
  "author": "User",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "tsc -b && vite build && electron-builder --win --dir",
    "electron:packager": "tsc -b && vite build && electron-packager . --overwrite --platform=win32 --arch=x64 --out=release-packager --icon=public/favicon.ico --ignore=\"^/(src|public|node_modules|release|release-build|release-packager|release-new|release-final|\\.git|\\.vscode|tests|\\.npmrc|vite\\.config\\.ts|tsconfig.*|.*\\.zip|.*\\.md)\""
  },
  "build": {
    "appId": "com.code.assistant",
    "productName": "CodeLearningAssistant",
    "directories": {
      "output": "release-build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "lucide-react": "^0.562.0",
    "monaco-editor": "^0.55.1",
    "openai": "^6.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "space-separated-tokens": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "cross-env": "^10.1.0",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "electron-packager": "^17.1.2",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1"
  }
}
